generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
}

//////////////////////////////////////////////////
// ENUMS (DB-mapped to preserve existing API string values)
//////////////////////////////////////////////////

enum Role {
  CUSTOMER @map("customer")
  VENDOR   @map("vendor")
  ADMIN    @map("admin")
  RIDER    @map("rider")
}

enum PaymentStatus {
  PENDING  @map("PENDING")
  PAID     @map("PAID")
  FAILED   @map("FAILED")
  REFUNDED @map("REFUNDED")
}

enum PaymentMethod {
  CARD          @map("CARD")
  OPAY          @map("OPAY")
  WALLET        @map("WALLET")
  NEXTGEN_PURSE @map("NEXTGEN_PURSE")
  EASYBUY       @map("EASYBUY")
  MAKOPA        @map("MAKOPA")
}

enum PaymentProvider {
  PAYSTACK    @map("PAYSTACK")
  FLUTTERWAVE @map("FLUTTERWAVE")
  MANUAL      @map("MANUAL")
}

enum DiscountType {
  PERCENTAGE @map("PERCENTAGE")
  FIXED      @map("FIXED")
}

enum DocumentReviewStatus {
  PENDING  @map("PENDING")
  APPROVED @map("APPROVED")
  REJECTED @map("REJECTED")
}

enum OrderStatus {
  ORDER_RECEIVED     @map("Order Received")
  CONFIRMED          @map("confirmed")
  PREPARING          @map("preparing")
  READY_FOR_DELIVERY @map("ready_for_delivery")
  OUT_FOR_DELIVERY   @map("out_for_delivery")
  DELIVERED          @map("delivered")
  CANCELLED          @map("cancelled")
}

enum DeliveryStatus {
  PENDING          @map("PENDING")
  PICKED_UP        @map("PICKED_UP")
  IN_TRANSIT       @map("IN_TRANSIT")
  OUT_FOR_DELIVERY @map("OUT_FOR_DELIVERY")
  DELIVERED        @map("DELIVERED")
  FAILED           @map("FAILED")
}

enum OnboardingStep {
  CREATED            @map("created")
  VERIFIED           @map("verified")
  VENDOR_UPDATED     @map("vendor_updated")
  STORE_CREATED      @map("store_created")
  PASSWORD_SET       @map("password_set")
  DOCUMENTS_UPLOADED @map("documents_uploaded")
  UNDER_REVIEW       @map("under_review")
  APPROVED           @map("approved")
}

enum NotificationType {
  ORDER_PLACED         @map("order_placed")
  ORDER_STATUS_UPDATE  @map("order_status_update")
  ORDER_CANCELLED      @map("order_cancelled")
  PAYMENT_RECEIVED     @map("payment_received")
  PAYMENT_FAILED       @map("payment_failed")
  VENDOR_APPROVED      @map("vendor_approved")
  VENDOR_REJECTED      @map("vendor_rejected")
  NEW_REVIEW           @map("new_review")
  PRODUCT_OUT_OF_STOCK @map("product_out_of_stock")
  DELIVERY_ASSIGNED    @map("delivery_assigned")
  DELIVERY_COMPLETED   @map("delivery_completed")
  SYSTEM_ANNOUNCEMENT  @map("system_announcement")
}

enum NotificationPriority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
  URGENT @map("urgent")
}

//////////////////////////////////////////////////
// USER MODEL
//////////////////////////////////////////////////

model User {
  id Int @id @default(autoincrement())

  firstName String?
  lastName  String?

  email    String  @unique
  password String?

  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  role String @default("customer")

  phoneNumber String?
  avatar      String?

  isEmailVerified Boolean @default(false)

  emailVerificationOTP        String?
  emailVerificationOTPExpires DateTime?

  onboardingStep String @default("created")

  isVerified Boolean @default(false)
  isActive   Boolean @default(true)

  state   String?
  city    String?
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  wishlist  WishlistItem[]

  // 1:1 (vendor store)
  store Store?

  // 1:1 (vendor profile)
  vendorProfile VendorProfile?

  // 1:1 cart
  cart Cart?

  // 1:n orders as customer
  orders Order[]

  notifications Notification[]
  reviews       Review[]

  chatConversationsAsAdmin ChatConversation[] @relation("ConversationAdmin")
  chatConversationsAsUser  ChatConversation[] @relation("ConversationUser")
  sentChatMessages         ChatMessage[]      @relation("ChatMessageSender")
}

model Address {
  id Int @id @default(autoincrement())

  label     String?
  state     String?
  city      String?
  address   String
  isDefault Boolean @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////
// WISHLIST
//////////////////////////////////////////////////

model WishlistItem {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

//////////////////////////////////////////////////
// PRODUCT MODEL
//////////////////////////////////////////////////

model Product {
  id Int @id @default(autoincrement())

  storeId Int?
  store   Store? @relation(fields: [storeId], references: [id])

  productName String
  description String

  price              Float
  discountPrice      Float  @default(0)
  discountPercentage Float  @default(0)
  discountType       String @default("fixed")

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  subCategoryId Int?
  subCategory   Category? @relation("SubCategoryRelation", fields: [subCategoryId], references: [id])

  stock     Int @default(0)
  totalSold Int @default(0)

  ratingsAverage Float @default(0)
  ratingsCount   Int   @default(0)

  expiryDate DateTime?

  // MySQL connector does not support primitive lists; use Json
  images Json

  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Opposite relations
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews       Review[]
}

//////////////////////////////////////////////////
// STORE MODEL
//////////////////////////////////////////////////

model Store {
  id Int @id @default(autoincrement())

  vendorId Int  @unique
  vendor   User @relation(fields: [vendorId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  storeName String

  state   String
  city    String
  address String

  isActive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  orders   Order[]

  cartItems CartItem[]
  reviews   Review[]
}

//////////////////////////////////////////////////
// CATEGORY MODEL
//////////////////////////////////////////////////

model Category {
  id Int @id @default(autoincrement())

  name String

  parentId Int?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  level Int

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  stores   Store[]

  subCategoryProducts Product[] @relation("SubCategoryRelation")
}

//////////////////////////////////////////////////
// VENDOR PROFILE MODEL
//////////////////////////////////////////////////

model VendorProfile {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  phoneNumber String?

  documents Json?

  documentReviewStatus String @default("pending")

  state   String
  city    String
  address String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////
// REVIEW MODEL
//////////////////////////////////////////////////

model Review {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  storeId Int
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  rating Int
  comment String?
  isVerifiedPurchase Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId, createdAt])
  @@index([storeId, createdAt])
}

//////////////////////////////////////////////////
// CART MODEL
//////////////////////////////////////////////////

model Cart {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  currency    String @default("NGN")
  shippingFee Float  @default(0)
  subtotal    Float  @default(0)
  totalItems  Int    @default(0)

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////
// CART ITEM MODEL
//////////////////////////////////////////////////

model CartItem {
  id Int @id @default(autoincrement())

  cartId Int
  cart   Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  storeId Int
  store   Store @relation(fields: [storeId], references: [id])

  quantity Int

  unitPrice  Float
  totalPrice Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////
// ORDER MODEL
//////////////////////////////////////////////////

model Order {
  id Int @id @default(autoincrement())

  orderNumber String @unique

  userId Int
  user   User @relation(fields: [userId], references: [id])

  storeId Int
  store   Store @relation(fields: [storeId], references: [id])

  items OrderItem[]

  customerName  String
  customerEmail String
  customerPhone String?

  shippingLabel   String?
  shippingState   String?
  shippingCity    String?
  shippingAddress String?

  currency String @default("NGN")

  subtotal    Float @default(0)
  shippingFee Float @default(0)
  taxAmount   Float @default(0)
  total       Float @default(0)

  currentStatus String @default("Order Received")

  payment  Payment?  @relation("OrderPayment")
  delivery Delivery? @relation("OrderDelivery")

  placedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([storeId, createdAt])
}

//////////////////////////////////////////////////
// ORDER ITEMS MODEL
//////////////////////////////////////////////////

model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  quantity Int

  unitPrice  Float
  totalPrice Float

  productName  String
  productCode  String?
  productImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}

//////////////////////////////////////////////////
// DELIVERY MODEL
//////////////////////////////////////////////////

model Delivery {
  id Int @id @default(autoincrement())

  orderId Int   @unique
  order   Order @relation("OrderDelivery", fields: [orderId], references: [id], onDelete: Cascade)

  riderName  String?
  riderId    String?
  riderEmail String?
  riderPhone String?

  deliveryService String?

  deliveryLabel   String?
  deliveryState   String?
  deliveryCity    String?
  deliveryAddress String

  trackingMapUrl String?

  status        String                 @default("pending")
  statusUpdates DeliveryStatusUpdate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////
// DELIVERY STATUS MODEL
//////////////////////////////////////////////////

model DeliveryStatusUpdate {
  id Int @id @default(autoincrement())

  deliveryId Int
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  status String

  location String?

  occurredAt DateTime @default(now())
}

//////////////////////////////////////////////////
// PAYMENT MODEL
//////////////////////////////////////////////////

model Payment {
  id Int @id @default(autoincrement())

  orderId Int   @unique
  order   Order @relation("OrderPayment", fields: [orderId], references: [id], onDelete: Cascade)

  amount Float

  currency String @default("NGN")

  subtotal    Float @default(0)
  shippingFee Float @default(0)
  taxAmount   Float @default(0)
  total       Float @default(0)

  paidByCustomer Float @default(0)

  status String @default("pending")

  paymentMethod String @default("card")

  provider String @default("paystack")

  transactionRef String? @unique

  paymentUrl String?

  paidAt DateTime?

  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////
// NOTIFICATION MODEL
//////////////////////////////////////////////////

model Notification {
  id Int @id @default(autoincrement())

  recipientId Int
  recipient   User @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  title   String
  message String

  type String

  data Json @default("{}")

  isRead Boolean   @default(false)
  readAt DateTime?

  priority String @default("medium")

  // Set by application code to mimic Mongo default (~30 days)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipientId, createdAt])
  @@index([recipientId, isRead])
  @@index([type, createdAt])
  @@index([expiresAt])
}

//////////////////////////////////////////////////
// CHAT MODELS
//////////////////////////////////////////////////

model ChatConversation {
  id Int @id @default(autoincrement())

  adminId Int
  admin   User @relation("ConversationAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  participantId Int
  participant   User @relation("ConversationUser", fields: [participantId], references: [id], onDelete: Cascade)

  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages ChatMessage[]

  @@unique([adminId, participantId])
  @@index([adminId, lastMessageAt])
  @@index([participantId, lastMessageAt])
}

model ChatMessage {
  id Int @id @default(autoincrement())

  conversationId Int
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId Int
  sender   User @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  body String @db.Text

  readAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([readAt])
}
