                {
                  "key": "phoneNumber",
                  "value": ""
                },
                {
                  "key": "state",
                  "value": ""
                },
                {
                  "key": "city",
                  "value": ""
                },
                {
                  "key": "address",
                  "value": ""
                },
                {
                  "key": "avatar",
                  "type": "file",
                  "src": ""
                }
              ]
