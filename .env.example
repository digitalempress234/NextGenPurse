# ============================================
# REQUIRED ENVIRONMENT VARIABLES
# ============================================
# These must be set for the application to start

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MySQL/MariaDB)
# Format: mysql://username:password@host:port/database_name
DATABASE_URL=mysql://username:password@localhost:3306/purse-backend

# JWT Configuration
# IMPORTANT: Use a minimum of 32 characters (64+ recommended for production)
# Generate a strong key: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_min_64_chars_for_production

# CORS Frontend URL
CLIENT_URL=http://localhost:3000

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# JWT Token Expiration
JWT_EXPIRES_IN=7d

# Email Configuration (Gmail App Password recommended)
# Remove # to enable email notifications
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Cloudinary Configuration (for image uploads)
# Remove # to enable image upload functionality
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Paystack Configuration (for payment processing)
# Get your keys from https://dashboard.paystack.com/
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here

# Base URL (for API callbacks and client links)
BASE_URL=http://localhost:5000

# Redis Configuration (for caching and job queues)
# Currently using for BullMQ job queue support
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================
# 1. Never commit .env to version control - add to .gitignore
# 2. For production, ensure JWT_SECRET is at least 64 characters and randomly generated
# 3. Store all secrets in your deployment platform (AWS Secrets Manager, Vercel, etc.)
# 4. Use environment-specific configuration for NODE_ENV
# 5. Update CLIENT_URL to your actual frontend domain
# 6. For Paystack webhooks, verify PAYSTACK_WEBHOOK_SECRET matches your dashboard
# 7. Set up SSL/TLS certificates (NODE_ENV=production should only work with HTTPS)
